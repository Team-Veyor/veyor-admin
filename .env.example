# veyor-admin 환경변수 (실제 값은 .env, 커밋 금지)
# ⚠️ veyor-app 과 "동일한" Supabase 프로젝트를 사용합니다.
# 값 위치: Supabase 대시보드 > Project Settings > API Keys

# 공개(브라우저) — 운영자 로그인(Supabase Auth)용
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# publishable key (sb_publishable_...) — 옛 anon key 대체. veyor-app 의 NEXT_PUBLIC_SUPABASE_ANON_KEY 와 동일 값
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# 서버 전용 — RLS 우회 관리 작업/접수 insert (⚠️ 절대 클라이언트 노출·커밋 금지)
SUPABASE_SECRET_KEY=sb_secret_...

# 어드민 접근 허용 운영자 이메일 (콤마로 여러 개). 비어 있으면 전원 차단.
ADMIN_ALLOWLIST=ops@example.com
